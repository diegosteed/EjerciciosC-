#include <iostream>
using namespace std;

int main(){

    float lado1,lado2,lado3,altura,angulo,area;
    string tipo_lados,tipo_angulos,mensaje;

    cout<<"Ingrese lado 1: ";
    cin>>lado1;

    cout<<"Ingrese lado 2: ";
    cin>>lado2;

    cout<<"Ingrese lado 3: ";
    cin>>lado3;

    cout<<"Ingrese altura: ";
    cin>>altura;

    cout<<"Ingrese angulo principal: ";
    cin>>angulo;

    if(lado1+lado2>lado3 && lado1+lado3>lado2 && lado2+lado3>lado1){

        cout<<"Triangulo valido\n";

        if(lado1==lado2 && lado2==lado3)
            tipo_lados="Equilatero";
        else if(lado1==lado2 || lado1==lado3 || lado2==lado3)
            tipo_lados="Isosceles";
        else
            tipo_lados="Escaleno";

        if(angulo<90)
            tipo_angulos="Acutangulo";
        else if(angulo==90)
            tipo_angulos="Rectangulo";
        else
            tipo_angulos="Obtusangulo";

        area=(lado1*altura)/2;

        if(altura>lado1 || altura>lado2 || altura>lado3)
            mensaje="Advertencia: altura inconsistente";
        else
            mensaje="Altura consistente";

        cout<<"Tipo por lados: "<<tipo_lados<<endl;
        cout<<"Tipo por angulos: "<<tipo_angulos<<endl;
        cout<<"Area: "<<area<<endl;
        cout<<mensaje<<endl;

    }
    else{
        cout<<"Los lados no forman un triangulo"<<endl;
    }

    return 0;
}
