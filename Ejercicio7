#include <iostream>
using namespace std;

int main(){

    float lectura_anterior, lectura_actual;
    int habitantes;
    int tipo_vivienda;
    bool artefactos, deuda;

    float consumo, costo_base, subsidio=0, recargo=0, total;

    cout<<"Lectura anterior: ";
    cin>>lectura_anterior;

    cout<<"Lectura actual: ";
    cin>>lectura_actual;

    cout<<"Tipo vivienda (1=Social 2=Normal): ";
    cin>>tipo_vivienda;

    cout<<"Numero de habitantes: ";
    cin>>habitantes;

    cout<<"Tiene artefactos alto consumo? (1=Si 0=No): ";
    cin>>artefactos;

    cout<<"Tiene deuda anterior? (1=Si 0=No): ";
    cin>>deuda;

    if(lectura_actual < lectura_anterior){
        cout<<"Dato invalido";
    }
    else{

        consumo = lectura_actual - lectura_anterior;

        if(consumo<=100)
            costo_base=consumo*0.10;
        else if(consumo<=300)
            costo_base=consumo*0.12;
        else
            costo_base=consumo*0.15;

        if(tipo_vivienda==1 && consumo<150)
            subsidio=costo_base*0.10;

        if(deuda)
            recargo=costo_base*0.05;

        total=costo_base-subsidio+recargo;

        cout<<"\nConsumo total: "<<consumo;
        cout<<"\nCosto base: "<<costo_base;
        cout<<"\nSubsidio: "<<subsidio;
        cout<<"\nRecargo: "<<recargo;
        cout<<"\nTotal final: "<<total;

        if(consumo/habitantes>80)
            cout<<"\nAlerta: consumo excesivo por habitante";

        if(artefactos && consumo>300)
            cout<<"\nAdvertencia: riesgo de sobrefacturacion";

    }

    return 0;
}
